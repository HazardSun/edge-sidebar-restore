{
  "manifest_version": 3,
  "name": "Edge 侧边栏恢复",
  "version": "0.2.0",
  "description": "恢复 Edge 被取消的侧边栏功能 — 原生侧面板零遮挡、页面快捷入口、搜索、计算器、单位换算、汇率、快速链接、笔记",
  "permissions": [
    "storage",
    "sidePanel",
    "declarativeNetRequestWithHostAccess"
  ],
  "host_permissions": [
    "*://*.google.com/*",
    "*://*.youtube.com/*",
    "*://*.googlevideo.com/*",
    "*://*.ytimg.com/*",
    "*://*.ggpht.com/*",
    "*://*.googleusercontent.com/*",
    "*://*.gstatic.com/*",
    "*://*.bing.com/*",
    "*://*.github.com/*",
    "*://*.reddit.com/*",
    "*://*.x.com/*",
    "*://*.twitter.com/*",
    "*://*.twimg.com/*",
    "*://*.chatgpt.com/*",
    "*://*.openai.com/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "ruleset_frame",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidebar.html"
  },
  "action": {
    "default_title": "打开/关闭侧边栏",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y"
      },
      "description": "打开/关闭侧边栏"
    }
  },
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
